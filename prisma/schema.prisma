generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  BUSINESS_OWNER
  ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  SUSPENDED
}

enum BusinessMemberRole {
  OWNER
  MANAGER
}

enum EventStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  CANCELED
}

enum VisibilityScope {
  GLOBAL
  USER_REGION
  SPECIFIC_REGION
}

enum CommunityPostStatus {
  PUBLISHED
  PENDING_REVIEW
  REMOVED
}

enum ReactionType {
  LIKE
}

enum SuggestionCategory {
  FUNCTIONALITY
  IMPROVEMENT
}

enum SuggestionStatus {
  NEW
  REVIEWED
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum CommunityGroupMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum BannerType {
  LINK
  REGISTRATION
}

enum BannerPlacement {
  HOME
  FEED
  BOTH
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  username            String?         @unique
  email               String?         @unique
  passwordHash        String?
  emailVerified       DateTime?
  image               String?
  coverImageUrl       String?
  bio                 String?
  interests           String[]        @default([])
  galleryUrls         String[]        @default([])
  role                UserRole        @default(USER)
  phone               String?
  locationLabel       String?
  regionKey           String?
  referredById        String?
  onboardingCompleted Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  accounts            Account[]
  sessions            Session[]
  businessMemberships BusinessMember[]
  createdBusinesses   Business[]      @relation("BusinessCreator")
  createdEvents       Event[]         @relation("EventCreator")
  communityPosts      CommunityPost[] @relation("CommunityPostAuthor")
  postComments        PostComment[]   @relation("PostCommentAuthor")
  postReactions       PostReaction[]  @relation("PostReactionAuthor")
  postReports         PostReport[]    @relation("PostReportAuthor")
  emailChangeTokens   EmailChangeToken[]
  suggestions         Suggestion[]
  businessFavorites   BusinessFavorite[]
  eventFavorites      EventFavorite[]
  businessRatings     BusinessRating[]
  eventRatings        EventRating[]
  analyticsEvents     AnalyticsEvent[]
  bannerRegistrations BannerRegistration[]
  sentFriendRequests  FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestRecipient")
  createdGroups       CommunityGroup[] @relation("CommunityGroupCreator")
  groupMemberships    CommunityGroupMember[]
  referredBy          User?           @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals           User[]          @relation("UserReferrals")

  @@index([referredById, createdAt])
}

model Region {
  key       String   @id
  label     String   @unique
  city      String
  state     String
  lat       Float
  lng       Float
  aliases   String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  banners   Banner[]
  communityGroups CommunityGroup[]
  businessVisibilityTargets Business[] @relation("BusinessVisibilityRegion")
  eventVisibilityTargets Event[] @relation("EventVisibilityRegion")

  @@index([isActive, label])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  userId     String
  newEmail   String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, newEmail])
  @@index([newEmail, expiresAt])
}

model Business {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  category      String
  description   String?
  phone         String?
  whatsapp      String?
  website       String?
  instagram     String?
  address       String
  locationLabel String
  regionKey     String
  visibilityScope VisibilityScope @default(USER_REGION)
  visibilityRegionKey String?
  imageUrl      String?
  galleryUrls   String[]        @default([])
  ratingAverage Float           @default(0)
  ratingCount   Int             @default(0)
  status        BusinessStatus  @default(PENDING_REVIEW)
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdBy     User            @relation("BusinessCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members       BusinessMember[]
  visibilityRegion Region?      @relation("BusinessVisibilityRegion", fields: [visibilityRegionKey], references: [key], onDelete: SetNull)
  favorites     BusinessFavorite[]
  ratings       BusinessRating[]
  communityPosts CommunityPost[] @relation("CommunityPostBusinessAuthor")
  events        Event[]          @relation("EventBusiness")

  @@index([status, regionKey])
  @@index([category, regionKey])
  @@index([visibilityScope, visibilityRegionKey])
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(OWNER)
  createdAt  DateTime           @default(now())
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
}

model Event {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String
  venueName     String
  startsAt      DateTime
  endsAt        DateTime?
  locationLabel String
  regionKey     String
  visibilityScope VisibilityScope @default(USER_REGION)
  visibilityRegionKey String?
  externalUrl   String?
  imageUrl      String?
  galleryUrls   String[]    @default([])
  ratingAverage Float       @default(0)
  ratingCount   Int         @default(0)
  status        EventStatus @default(PENDING_REVIEW)
  businessId    String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdBy     User        @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  business      Business?   @relation("EventBusiness", fields: [businessId], references: [id], onDelete: SetNull)
  visibilityRegion Region?  @relation("EventVisibilityRegion", fields: [visibilityRegionKey], references: [key], onDelete: SetNull)
  favorites     EventFavorite[]
  ratings       EventRating[]

  @@index([status, regionKey, startsAt])
  @@index([visibilityScope, visibilityRegionKey, startsAt])
  @@index([businessId, startsAt])
}

model CommunityPost {
  id            String              @id @default(cuid())
  content       String              @db.Text
  imageUrl      String?
  externalUrl   String?
  status        CommunityPostStatus @default(PUBLISHED)
  authorId      String
  businessAuthorId String?
  regionKey     String
  locationLabel String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  author        User                @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  businessAuthor Business?          @relation("CommunityPostBusinessAuthor", fields: [businessAuthorId], references: [id], onDelete: SetNull)
  comments      PostComment[]
  reactions     PostReaction[]
  reports       PostReport[]

  @@index([status, regionKey, createdAt])
  @@index([businessAuthorId, createdAt])
}

model PostComment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  content   String        @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation("PostCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model PostReaction {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  type      ReactionType  @default(LIKE)
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation("PostReactionAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId, type])
}

model PostReport {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  reason    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation("PostReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId])
}

model Banner {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  type      BannerType @default(LINK)
  placement BannerPlacement @default(HOME)
  targetUrl String?
  regionKey String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  region    Region?  @relation(fields: [regionKey], references: [key], onDelete: SetNull)
  registrations BannerRegistration[]

  @@index([isActive, regionKey, updatedAt])
}

model BannerRegistration {
  id            String   @id @default(cuid())
  bannerId      String
  userId        String
  name          String?
  email         String?
  phone         String?
  regionKey     String?
  locationLabel String?
  createdAt     DateTime @default(now())
  banner        Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bannerId, userId])
  @@index([bannerId, createdAt])
  @@index([userId, createdAt])
}

model BusinessFavorite {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId, createdAt])
}

model EventFavorite {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, createdAt])
}

model BusinessRating {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  stars      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId, updatedAt])
}

model EventRating {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, updatedAt])
}

model FriendRequest {
  id          String              @id @default(cuid())
  requesterId String
  recipientId String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  requester   User                @relation("FriendRequestSender", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User                @relation("FriendRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status, createdAt])
}

model CommunityGroup {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  imageUrl    String?
  category    String?
  regionKey   String?
  isPublic    Boolean                @default(true)
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  createdBy   User                   @relation("CommunityGroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  region      Region?                @relation(fields: [regionKey], references: [key], onDelete: SetNull)
  members     CommunityGroupMember[]

  @@index([isPublic, createdAt])
  @@index([regionKey, createdAt])
  @@index([createdById, createdAt])
}

model CommunityGroupMember {
  id        String                   @id @default(cuid())
  groupId   String
  userId    String
  role      CommunityGroupMemberRole @default(MEMBER)
  createdAt DateTime                 @default(now())
  group     CommunityGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, createdAt])
  @@index([groupId, createdAt])
}

model Suggestion {
  id        String             @id @default(cuid())
  category  SuggestionCategory
  message   String             @db.Text
  status    SuggestionStatus   @default(NEW)
  userId    String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  type          String
  targetType    String
  targetKey     String
  label         String
  sourcePath    String?
  sourceSection String?
  regionKey     String?
  userId        String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([targetType, targetKey, createdAt])
  @@index([userId, createdAt])
  @@index([sourceSection, createdAt])
}
